{
  "name": "sentinel-ai",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "bootstrap": "./scripts/bootstrap.sh",
    "build": "turbo run build",
    "check-env": "./scripts/check-env.sh",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check-types": "bun run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.5",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
