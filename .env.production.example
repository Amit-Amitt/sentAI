# ==============================================================================
# SENTINEL AI - PRODUCTION ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to `.env` on your production server or use it to populate
# Kubernetes Secrets. ALL values here must be populated with real production credentials.

# ------------------------------------------
# GENERAL ENVIRONMENT
# ------------------------------------------
SENTINEL_APP_ENV="production"
SENTINEL_LOG_LEVEL="WARNING"
SENTINEL_API_HOST="0.0.0.0"
SENTINEL_API_PORT=8000
SENTINEL_CORS_ORIGINS="https://app.yourcompany.com"

# ------------------------------------------
# DATABASE (REQUIRED)
# ------------------------------------------
SENTINEL_DATABASE_URL="postgresql+psycopg://USER:PASSWORD@HOST:5432/sentinel_prod"
SENTINEL_DATABASE_POOL_SIZE=20
SENTINEL_DATABASE_SSL_MODE="require"

# ------------------------------------------
# REDIS & QUEUE (REQUIRED)
# ------------------------------------------
SENTINEL_REDIS_URL="redis://:PASSWORD@HOST:6379/0"
SENTINEL_QUEUE_CONCURRENCY=20
SENTINEL_QUEUE_RETRY_COUNT=5

# ------------------------------------------
# AUTHENTICATION & SECURITY (REQUIRED)
# ------------------------------------------
# Must be at least 32 characters long
SENTINEL_JWT_SECRET=""
SENTINEL_JWT_EXPIRES_IN=3600
# Must be exactly 32 bytes (base64 encoded)
SENTINEL_AUTH_ENCRYPTION_KEY=""

# ------------------------------------------
# AI PROVIDERS
# ------------------------------------------
SENTINEL_OPENAI_API_KEY=""
SENTINEL_OPENAI_MODEL="gpt-4o"
SENTINEL_GEMINI_API_KEY=""
SENTINEL_GEMINI_MODEL="gemini-1.5-pro"
SENTINEL_ANTHROPIC_API_KEY=""

# ------------------------------------------
# EXTERNAL INTEGRATIONS
# ------------------------------------------
SENTINEL_GITHUB_APP_ID=""
SENTINEL_GITHUB_PRIVATE_KEY=""
SENTINEL_GITHUB_WEBHOOK_SECRET=""
SENTINEL_S3_ENDPOINT=""
SENTINEL_S3_BUCKET=""
SENTINEL_RESEND_API_KEY=""

# ------------------------------------------
# BILLING & STRIPE
# ------------------------------------------
SENTINEL_STRIPE_SECRET_KEY=""
SENTINEL_STRIPE_PUBLISHABLE_KEY=""
SENTINEL_STRIPE_WEBHOOK_SECRET=""
SENTINEL_STRIPE_PRICE_FREE=""
SENTINEL_STRIPE_PRICE_STARTER=""
SENTINEL_STRIPE_PRICE_PRO=""
SENTINEL_STRIPE_PRICE_ENTERPRISE=""
SENTINEL_DEFAULT_CURRENCY="usd"
