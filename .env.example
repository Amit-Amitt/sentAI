# ==============================================================================
# SENTINEL AI - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to `.env` and replace the placeholder values.
# The application will refuse to start if REQUIRED variables are missing.

# ------------------------------------------
# GENERAL ENVIRONMENT
# ------------------------------------------
SENTINEL_APP_ENV="development"
SENTINEL_LOG_LEVEL="INFO"
SENTINEL_API_HOST="0.0.0.0"
SENTINEL_API_PORT=8000
SENTINEL_CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ------------------------------------------
# DATABASE (REQUIRED)
# ------------------------------------------
SENTINEL_DATABASE_URL="postgresql+psycopg://sentinel:sentinel@localhost:5432/sentinel_ai"
SENTINEL_DATABASE_POOL_SIZE=10
SENTINEL_DATABASE_SSL_MODE="prefer"

# ------------------------------------------
# REDIS & QUEUE (REQUIRED)
# ------------------------------------------
SENTINEL_REDIS_URL="redis://localhost:6379/0"
SENTINEL_QUEUE_CONCURRENCY=5
SENTINEL_QUEUE_RETRY_COUNT=3

# ------------------------------------------
# AUTHENTICATION (REQUIRED)
# ------------------------------------------
SENTINEL_JWT_SECRET="your_super_secret_jwt_key_change_in_production"
SENTINEL_JWT_EXPIRES_IN=3600
SENTINEL_AUTH_ENCRYPTION_KEY="your_super_secret_encryption_key_change_in_production"

# ------------------------------------------
# FEATURE FLAGS
# ------------------------------------------
# Toggle major subsystems on or off. Defaults to true.
SENTINEL_ENABLE_AI=true
SENTINEL_ENABLE_GITHUB=true
SENTINEL_ENABLE_OTEL=true
SENTINEL_ENABLE_KUBERNETES=true
SENTINEL_ENABLE_PROMETHEUS=true
SENTINEL_ENABLE_AUTO_REMEDIATION=true
SENTINEL_ENABLE_NOTIFICATIONS=true

# ------------------------------------------
# AI PROVIDERS
# ------------------------------------------
SENTINEL_OPENAI_API_KEY="your_openai_api_key_here"
SENTINEL_OPENAI_MODEL="gpt-4o"
SENTINEL_GEMINI_API_KEY="your_gemini_api_key_here"
SENTINEL_GEMINI_MODEL="gemini-1.5-pro"
SENTINEL_ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# ------------------------------------------
# VECTOR DATABASE
# ------------------------------------------
SENTINEL_QDRANT_URL="http://localhost:6333"
SENTINEL_QDRANT_API_KEY=""

# ------------------------------------------
# GITHUB INTELLIGENCE
# ------------------------------------------
SENTINEL_GITHUB_APP_ID="123456"
SENTINEL_GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
SENTINEL_GITHUB_WEBHOOK_SECRET="super-secret-webhook-key"

# ------------------------------------------
# KUBERNETES RUNTIME
# ------------------------------------------
SENTINEL_K8S_IN_CLUSTER=false
SENTINEL_K8S_KUBECONFIG_PATH="~/.kube/config"

# ------------------------------------------
# OBSERVABILITY INTEGRATIONS
# ------------------------------------------
SENTINEL_PROMETHEUS_URL="http://prometheus:9090"
SENTINEL_GRAFANA_URL="http://grafana:3000"
SENTINEL_GRAFANA_API_KEY="ey..."
SENTINEL_LOKI_URL="http://loki:3100"
SENTINEL_TEMPO_URL="http://tempo:3200"
SENTINEL_ALERTMANAGER_URL="http://alertmanager:9093"

# ------------------------------------------
# STORAGE & NOTIFICATIONS
# ------------------------------------------
SENTINEL_S3_ENDPOINT=""
SENTINEL_S3_BUCKET=""
SENTINEL_RESEND_API_KEY=""

# ------------------------------------------
# IDENTITY & SSO
# ------------------------------------------
SENTINEL_GOOGLE_CLIENT_ID=""
SENTINEL_GOOGLE_CLIENT_SECRET=""
SENTINEL_MICROSOFT_CLIENT_ID=""
SENTINEL_MICROSOFT_CLIENT_SECRET=""
SENTINEL_SAML_IDP_URL=""

# ------------------------------------------
# BILLING & STRIPE
# ------------------------------------------
SENTINEL_STRIPE_SECRET_KEY=""
SENTINEL_STRIPE_PUBLISHABLE_KEY=""
SENTINEL_STRIPE_WEBHOOK_SECRET=""
SENTINEL_STRIPE_PRICE_FREE="price_free_123"
SENTINEL_STRIPE_PRICE_STARTER="price_starter_123"
SENTINEL_STRIPE_PRICE_PRO="price_pro_123"
SENTINEL_STRIPE_PRICE_ENTERPRISE="price_enterprise_123"
SENTINEL_DEFAULT_CURRENCY="usd"
